# WebSocket server mode — used with: node dist/index.js --server

PORT=18790
AUTH_TOKEN=CHANGE_ME_generate_with_openssl_rand_hex_32

# Command to spawn for each connection (defaults to re-spawning self in stdio mode)
# CLAUDE_AGENT_CMD=claude-agent-acp
# CLAUDE_AGENT_ARGS=

# Anthropic API key (passed to child processes)
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# TLS (optional — skip for private/Tailscale networks)
# TLS_CERT_PATH=/path/to/cert.pem
# TLS_KEY_PATH=/path/to/key.pem

MAX_CONNECTIONS=10
LOG_LEVEL=info
